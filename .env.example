# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amazon_intel

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=amazon_intel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Apify (replaces Keepa — free tier at https://apify.com) ──────────────────
APIFY_API_KEY=your-apify-api-token

# ── Scraper proxy (not needed — Apify handles proxies internally) ─────────────
# SCRAPER_PROXY_URL is no longer used

# ── NLP ──────────────────────────────────────────────────────────────────────
NLP_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
NLP_BATCH_SIZE=64

# ── Monitoring ───────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy
