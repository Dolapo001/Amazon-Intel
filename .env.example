# ── Django ───────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_DEBUG=False
# On Heroku, set ALLOWED_HOSTS to your app domain, e.g. my-app.herokuapp.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Postgres ─────────────────────────────────────────────────────────────────
# On Heroku, DATABASE_URL is set automatically by the Heroku Postgres add-on.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amazon_intel

# ── ClickHouse ───────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DB=amazon_intel
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Redis ────────────────────────────────────────────────────────────────────
# On Heroku, REDIS_URL is set automatically by the Heroku Redis add-on.
# The production.py settings derive CELERY_BROKER_URL / CELERY_RESULT_BACKEND
# from REDIS_URL, so you only need to set REDIS_URL in most cases.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── Apify (replaces Keepa — free tier at https://apify.com) ──────────────────
APIFY_API_KEY=your-apify-api-token

# ── Rainforest (alternative — free trial at https://rainforestapi.com) ────────
RAINFOREST_API_KEY=your-rainforest-api-key

# ── NLP ──────────────────────────────────────────────────────────────────────
NLP_SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest
NLP_BATCH_SIZE=64

# ── Monitoring ───────────────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/yyy

# ── Heroku SSL (production.py defaults to True; override here for local dev) ──
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

