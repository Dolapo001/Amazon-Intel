FROM python:3.11-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
      "mcp==1.3.0" \
      "fastmcp>=2.3.0" \
      "ctxprotocol>=0.3.0" \
      "httpx==0.27.0" \
      "uvicorn>=0.30" \
      "starlette>=0.37"


# Copy proxy script
COPY mcp_proxy.py .

# Environment Defaults
ENV BACKEND_URL=http://web:5000
ENV PORT=3000

# Run mcp server
ENTRYPOINT ["python", "mcp_proxy.py"]
